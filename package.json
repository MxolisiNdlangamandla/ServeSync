{
  "name": "servesync",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "server": "node server/index.js",
    "dev": "concurrently \"ng serve\" \"node server/index.js\"",
    "build:prod": "ng build --configuration production",
    "start:prod": "node server/index.js"
  },
